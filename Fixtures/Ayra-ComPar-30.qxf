  <Capability Min="102" Max="118">Lavender</Capability>
  <Capability Min="119" Max="135">Pink</Capability>
  <Capability Min="136" Max="152">Bright Green</Capability>
  <Capability Min="153" Max="169">Magenta</Capability>
  <Capability Min="170" Max="186">Pale Pink</Capability>
  <Capability Min="187" Max="203">Amber</Capability>
  <Capability Min="204" Max="220">Bright Magenta</Capability>
  <Capability Min="221" Max="237">Pale Cyan</Capability>
  <Capability Min="238" Max="255">Warm White</Capability>
 </Channel>
 <Channel Name="Strobe slow-fast" Preset="ShutterStrobeSlowFast"/>

  <Capability Min="0" Max="4">Blackout</Capability>
  <Capability Min="5" Max="80">Colour 1-15</Capability>
  <Capability Min="81" Max="150">Colour jump (slow to fast)</Capability>
  <Capability Min="151" Max="220">Colour fade (slow to fast)</Capability>
